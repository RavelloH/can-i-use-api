{
  "id": "console-basic",
  "title": "Basic console logging functions",
  "description": "Method of outputting data to the browser's console, intended for development purposes.",
  "spec": "https://console.spec.whatwg.org/",
  "status": "ls",
  "categories": [
    "JS API"
  ],
  "keywords": [
    "api",
    "basic",
    "console",
    "console.error",
    "console.info",
    "console.log",
    "console.warn",
    "error",
